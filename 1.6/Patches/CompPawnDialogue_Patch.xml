<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- Use PatchOperationAdd to add CompPawnDialogue to all Human pawns safely -->
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="Human"]/comps</xpath>
        <value>
            <li Class="RimChat.Comp.CompProperties_PawnDialogue" />
        </value>
    </Operation>
</Patch>
