<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- Use PatchOperationAdd to add CompPawnDialogue to Human def safely -->
    <Operation Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="Human"]/comps[not(li[@Class='RimChat.Comp.CompProperties_PawnDialogue'])]</xpath>
        <value>
            <li Class="RimChat.Comp.CompProperties_PawnDialogue" />
        </value>
    </Operation>
</Patch>
