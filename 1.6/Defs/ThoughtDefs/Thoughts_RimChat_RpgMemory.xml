<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- Dependencies: RimWorld ThoughtDef loader, DefInjected ThoughtDef labels/descriptions. -->
  <!-- Responsibility: define the custom RPG dialogue memories used by RimChat TryGainMemory. -->

  <!-- Tier 1: surface affects -->

  <ThoughtDef>
    <defName>RimChat_BriefJoy</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>0.25</durationDays>
    <stackLimit>10</stackLimit>
    <stackedEffectMultiplier>0.85</stackedEffectMultiplier>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <stages>
      <li>
        <label>moment of joy</label>
        <description>That brief moment of joy lifted my spirits.</description>
        <baseMoodEffect>2</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

